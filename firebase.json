{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "farmassistant-54d84",
          "appId": "1:698540357194:android:e3380e1e65a0cf6aa498b3",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "farmassistant-54d84",
          "configurations": {
            "android": "1:698540357194:android:e3380e1e65a0cf6aa498b3",
            "ios": "1:698540357194:ios:3286a7ab26e8b484a498b3",
            "web": "1:698540357194:web:b07fdb2195fd936ea498b3"
          }
        }
      },
      "ios": {
        "default": {
          "projectId": "farmassistant-54d84",
          "appId": "1:698540357194:ios:3286a7ab26e8b484a498b3",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      }
    }
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "robot",
      "codebase": "robot",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ]
    }
  ],
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Permissions-Policy",
            "value": "camera=(self), microphone=(), geolocation=()"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}